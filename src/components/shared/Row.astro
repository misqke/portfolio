---
const {align = "center", justify = "center", gap = "1rem"} = Astro.props;
---

<div>
  <slot />
</div>

<style define:vars={{align, justify, gap}}>
  div{
    display: flex;
    flex-direction: row;
    justify-content: var(--justify);
    align-items: var(--align);
    gap: var(--gap);
  }
</style>