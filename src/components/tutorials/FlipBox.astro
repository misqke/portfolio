---
const {width = "100%", height = "100%", bgFront = "#444", bgBack = "#444", textFront = "#ddd", textBack = "#ddd", title = "Hello World"} = Astro.props;
---

<div class="flip-box">
  <div class="card-container">
    <div class="card-face front">
      <p class="card-title">{title}</p>
    </div>
    <div class="card-face back">
      <slot />
    </div>
    
  </div>
</div>

<style define:vars={{width, height, bgFront, bgBack, textFront, textBack}}>
  .flip-box {
    perspective: 450px;
    width: var(--width);
    height: var(--height); 
  }
  .card-container{
    width: 100%;
    height: 100%;
    position: relative;
    transition-duration: 500ms;
    backface-visibility: hidden;
    text-align: center;
  }
  .card-title{
    font-size: 1.5rem;
    font-weight: 600px;
    color: var(--textFront);
  }
  .card-face::before{
    content: "";
    position: absolute;
    bottom: -40px;
    width: 100%;
    box-shadow: 0px 0px 20px 2px var(--neutral);
  }
  .flip-box:hover .card-container {
    transform: rotateY(180deg);
  }
  .card-face{
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .card-face.front {
    background: var(--bgFront);
    z-index:2;
  }
  .card-face.back {
    background: var(--bgBack);
    transform: rotateY(180deg);
    color: var(--textBack);
  }
</style>